#!/usr/bin/env bash
set -e

install_dotenv() {
  local install_type=$1
  local version=$2
  local install_path=$3
  local download_path=$4

  if [ "$install_type" != "version" ]; then
    echo "asdf-dotenv supports release installs only"
    exit 1
  fi

  # Handle Windows
  local platform=$(uname -s | tr '[:upper:]' '[:lower:]')
  local ext=""
  if [ "$platform" = "windows" ] || [[ "$platform" =~ mingw|msys|cygwin ]]; then
    ext=".exe"
  fi

  local binary="$download_path/dotenv${ext}"
  if [ ! -f "$binary" ]; then
    echo "Downloaded binary not found at $binary"
    exit 1
  fi

  mkdir -p "$install_path/bin"
  cp "$binary" "$install_path/bin/dotenv${ext}"
  chmod +x "$install_path/bin/dotenv${ext}"

  echo "dotenv-cli v${version} installed successfully!"
}

install_dotenv "$ASDF_INSTALL_TYPE" "$ASDF_INSTALL_VERSION" "$ASDF_INSTALL_PATH" "$ASDF_DOWNLOAD_PATH"
